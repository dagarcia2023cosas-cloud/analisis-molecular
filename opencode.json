{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "pdb": {
      "type": "local",
      "command": ["node", "Herramientas/mcp-servers/PDB-MCP-Server/build/index.js"],
      "enabled": true
    },
    "pubchem": {
      "type": "local",
      "command": ["npx", "-y", "pubchem-mcp"],
      "enabled": true
    },
    "chembl": {
      "type": "local",
      "command": ["node", "Herramientas/mcp-servers/ChEMBL-MCP-Server/build/index.js"],
      "enabled": true
    },
    "rosetta": {
      "type": "local",
      "command": ["npx", "-y", "rosetta-mcp-server"],
      "enabled": true
    }
  }
}
