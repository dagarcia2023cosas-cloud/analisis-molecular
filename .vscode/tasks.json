{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install package (editable)",
      "type": "shell",
      "command": "pip install -e .",
      "options": {"cwd": "${workspaceFolder}"},
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Install all deps (conda)",
      "type": "shell",
      "command": "conda env create -f environment.yml",
      "options": {"cwd": "${workspaceFolder}"},
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Run all tests",
      "type": "shell",
      "command": "python -m pytest tests/ -v",
      "options": {"cwd": "${workspaceFolder}"},
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Run specific test file",
      "type": "shell",
      "command": "python -m pytest ${file} -v",
      "options": {"cwd": "${workspaceFolder}"},
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Format code (black)",
      "type": "shell",
      "command": "python -m black src/ tests/",
      "options": {"cwd": "${workspaceFolder}"},
      "group": "format",
      "problemMatcher": []
    },
    {
      "label": "Lint code (ruff)",
      "type": "shell",
      "command": "python -m ruff check src/ tests/",
      "options": {"cwd": "${workspaceFolder}"},
      "group": "format",
      "problemMatcher": []
    },
    {
      "label": "Sync to Colab - generate notebook cell",
      "type": "shell",
      "command": "python scripts/sync_to_colab.py",
      "options": {"cwd": "${workspaceFolder}"},
      "group": "none",
      "problemMatcher": []
    }
  ]
}
